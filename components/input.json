{
  "component": "input",

  "anatomy": {
    "label": true,
    "control": true,
    "supportingText": true,
    "selectionInfobox": true
  },

  "orientation": {
    "vertical": {
      "gap": "spacing.xs"
    },

    "horizontal": {
      "gap": "spacing.sm"
    }
  },

  "label": {
    "typography": "typography.label",
    "color": "theme.system.foreground",

    "metadata": {
      "optional": false,
      "metric": false,
      "counter": false,
      "questionIcon": false,
      "infoIcon": false
    },

    "icons": {
      "question": {
        "typography": "typography.icon",
        "color": "theme.system.foreground70"
      },

      "info": {
        "typography": "typography.icon",
        "color": "theme.accent.default"
      }
    },

    "gap": "spacing.xs"
  },

  "controlTypes": {
    "textfield": {},
    "radioGroup": {},
    "checkboxGroup": {},
    "fileUpload": {},
    "multiSelect": {}
  },

  "supportingText": {
    "typography": "typography.small"
  },

  "selectionInfobox": {
    "component": "infobox"
  },

  "states": {
    "default": {
      "supportingText": "theme.system.foreground"
    },

    "error": {
      "supportingText": "theme.negative.background"
    }
  }
}
