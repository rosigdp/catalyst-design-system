{
  "component": "textAction",

  "content": {
    "text": {
      "typography": "typography.link"
    }
  },

  "variants": {
    "link": {
      "text": "theme.accent.default"
    },

    "action": {
      "text": "theme.brand.default"
    },

    "destructive": {
      "text": "theme.system.foreground70"
    }
  },

  "states": {
    "hover": {
      "link": {
        "overlayColor": "theme.system.foreground20"
      },

      "action": {
        "overlayColor": "theme.system.foreground20"
      },

      "destructive": {
        "text": "theme.negative.background"
      }
    },

    "focus": {
      "outlineWidth": 2,
      "outlineColor": "theme.accent.default",
      "outlineRadius": "radius.default"
    }
  }
}