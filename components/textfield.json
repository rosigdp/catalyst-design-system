{
  "component": "textfield",

  "base": "input",

  "radius": "radius.default",

  "content": {
    "value": {
      "typography": "typography.body",
      "color": "theme.system.foreground"
    },

    "placeholder": {
      "typography": "typography.body",
      "color": "theme.system.foreground70"
    },

    "leadingIcon": {
      "typography": "typography.icon",
      "color": "theme.system.foreground70"
    },

    "trailingIcon": {
      "typography": "typography.icon",
      "color": "theme.system.foreground70"
    },

    "gap": "spacing.sm"
  },

  "modes": {
    "edit": {
      "sizes": {
        "default": {
          "paddingY": "spacing.sm",
          "paddingX": "spacing.md"
        }
      }
    },

    "view": {}
  },

  "types": {
    "singleLine": {
      "textWrap": false,
      "resize": false
    },

    "multiLine": {
      "textWrap": true,
      "resize": true
    }
  },

  "addons": {
    "leadingButton": {
      "component": "button.secondary"
    },

    "trailingButton": {
      "component": "button.secondary"
    }
  },

  "states": {
    "default": {
      "background": "theme.system.background",
      "text": "theme.system.foreground",
      "border": {
        "width": 1,
        "color": "theme.system.foreground20"
      }
    },

    "focus": {
      "border": {
        "width": 1,
        "color": "theme.brand.default"
      },
      "effect": "effects.focus.glow"
    },

    "error": {
      "background": "theme.system.background",
      "text": "theme.system.foreground",
      "border": {
        "width": 1,
        "color": "theme.negative.background"
      }
    },

    "disabled": {
      "background": "theme.disable.background",
      "text": "theme.disable.foreground",
      "border": {
        "width": 1,
        "color": "theme.disable.foreground20"
      }
    }
  }
}
