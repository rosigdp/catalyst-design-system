{
  "shadow": {
    "sm": {
      "offsetX": 0,
      "offsetY": 1,
      "blur": 5,
      "spread": 2,
      "color": "theme.system.shadowElevation"
    },

    "lg": {
      "offsetX": 0,
      "offsetY": 2,
      "blur": 8,
      "spread": 0,
      "color": "theme.system.shadowElevation"
    }
  },

  "focus": {
    "outline": {
      "outlineWidth": 2,
      "outlineColor": "theme.accent.default",
      "radiusOffset": 3
    },

    "glow": {
      "offsetX": 0,
      "offsetY": 0,
      "blur": 6,
      "spread": 0,
      "color": "theme.brand.50"
    }
  }
}
